{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "planaiq",
  "main": "worker.js",
  "compatibility_date": "2026-04-12",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
